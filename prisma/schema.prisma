generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  
  // Subscription & Usage
  subscriptionTier String   @default("free") // "free" | "pro" | "enterprise"
  stripeCustomerId String?  @unique
  stripeSubscriptionId String? @unique
  stripePriceId String?
  stripeCurrentPeriodEnd DateTime?
  stripeCancelAtPeriodEnd Boolean @default(false)
  usageProjects    Int      @default(0)
  usageApiCalls    Int      @default(0)
  
  // Protocol Settings
  autoGenEnabled     Boolean @default(true)
  codeContextEnabled Boolean @default(true)
  apiScannerEnabled  Boolean @default(true)
  pushNotificationsEnabled Boolean @default(true)
  
  // AI Keys
  openaiKey        String?
  anthropicKey     String?
  googleKey        String?
  mistralKey       String?
  cohereKey        String?
  deepseekKey      String?

  accounts  Account[]
  sessions  Session[]
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  source      String   // "github" | "upload"
  repoUrl     String?
  language    String?
  framework   String?
  status      String   @default("processing") // "processing" | "completed" | "error"
  lastUpdated DateTime @default(now())
  pages       Int      @default(0)
  diagrams    Int      @default(0)
  coverage    Int      @default(0)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  content     String?

  // Deep Analysis Storage
  aiInsights   String? // JSON string: { architecture: string, keyModules: [], dependencies: [], security: [] }
  analysisData String? // JSON string: { fileCount: number, totalLines: number, framework: string, entryPoints: [] }
  fileTree     String? // JSON string representing the file hierarchy

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
